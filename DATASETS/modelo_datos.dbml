// =============================================================================
// Modelo lógico de datos — Proyecto VDD (Bogotá)
// Esquema estrella para Power BI / SQL
// Fuente: data/ + nuevas-tablas/
// Visualizar en https://dbdiagram.io
// =============================================================================

Project vdd_bogota_seguridad {
  database_type: 'PostgreSQL'
  Note: '''
    **Hechos:** hurtos (nivel municipio), llamadas 123 (nivel UPZ).
    **Limitaciones:** hurtos sin FK a upz/localidad; población en upz es proxy.
    Cargar calendar 2020-01-01 a 2025-12-31 desde Calendar.csv.
  '''
}

// -----------------------------------------------------------------------------
// Dimensiones
// -----------------------------------------------------------------------------

Table calendar {
  fecha date [pk, note: 'Calendar.csv — columna Date']

  Note: 'Dimensión tiempo. 2 192 días (2020–2025).'
}

Table genero {
  genero varchar(30) [pk]

  Note: 'Genero.csv'
}

Table arma_medio {
  armas_medios varchar(80) [pk]

  Note: 'ArmaMedio.csv'
}

Table localidad {
  cod_localidad varchar(5) [pk]
  localidad varchar(80) [not null]

  Note: 'Localidad.csv — 21 localidades Bogotá'
}

Table franja_horaria {
  rango_hora varchar(20) [pk]
  rango_del_dia varchar(20) [not null]
  dummy_key smallint [not null, default: 1]

  Note: 'FranjaHoraria.csv — 8 franjas'
}

Table upz {
  cod_upz varchar(10) [pk]
  objectid int [not null, unique]
  nombre_upz varchar(120) [not null]
  poblacion_proxy int [note: 'Proxy CMHPTOTAL — no censo 2025']
  area_km2 decimal(12,4) [note: 'km² en EPSG:9377']
  // geom geometry [note: 'PostGIS — importar desde DAIUPZ.geojson']

  Note: 'DAIUPZ.geojson — 116 polígonos'
}

Table intervencion {
  id_intervencion int [pk, increment]
  nombre varchar(200) [not null]
  fecha_inicio date [not null]
  fecha_fin date
  descripcion varchar(500)

  Note: 'Opcional — fechas de intervención (objetivo 4). No viene en CSV.'
}

// -----------------------------------------------------------------------------
// Hechos
// -----------------------------------------------------------------------------

Table hurtos_bogota_2025 {
  id_hurto bigint [pk, increment]
  fecha_hecho date [not null, ref: > calendar.fecha]
  anio smallint [not null]
  mes smallint [not null]
  dia_semana smallint [not null]
  nombre_dia varchar(15) [not null]
  genero varchar(30) [not null, ref: > genero.genero, note: 'Mapear SIN_DATO → No Informado']
  agrupa_edad varchar(30) [not null]
  armas_medios varchar(80) [not null, ref: > arma_medio.armas_medios]
  departamento varchar(60) [not null]
  municipio varchar(80) [not null]
  codigo_dane varchar(12) [not null, note: '11001000 — solo nivel municipio']
  nivel_geografico varchar(20) [not null, default: 'municipio']
  cantidad int [not null, note: 'Suma conserva 100 017 casos']

  indexes {
    (fecha_hecho, genero, agrupa_edad, armas_medios) [unique, name: 'uq_hurtos_grano']
    fecha_hecho [name: 'ix_hurtos_fecha']
    (anio, mes) [name: 'ix_hurtos_anio_mes']
  }

  Note: 'hurtos_bogota_2025.csv — 3 982 filas agregadas'
}

Table llamadas_123 {
  id_incidente varchar(40) [pk]
  fecha date [not null, ref: > calendar.fecha]
  anio char(4) [not null]
  mes char(2) [not null]
  semana_iso varchar(3)
  num_dia_semana varchar(2)
  nombre_dia varchar(15) [not null]
  rango_hora varchar(20) [not null, ref: > franja_horaria.rango_hora]
  rango_del_dia varchar(20) [not null]
  tipo_incidente varchar(20) [not null]
  desc_tipo_incidente varchar(120)
  circunstancia_incidente varchar(120)
  cod_localidad varchar(5) [not null, ref: > localidad.cod_localidad]
  localidad varchar(80) [not null]
  cod_upz varchar(10) [not null, ref: > upz.cod_upz]
  nombre_upz varchar(120) [not null]
  cod_barrio varchar(20)
  barrio varchar(120)
  latitud decimal(10,7)
  longitud decimal(11,7)
  direccion varchar(200)
  cod_agencia varchar(10)
  agencia varchar(80)
  sin_localizacion smallint [not null, default: 0, note: '0/1']
  coord_valida smallint [not null, default: 0, note: '0/1']
  upz_valida smallint [not null, default: 0, note: '0/1']

  indexes {
    fecha [name: 'ix_llamadas_fecha']
    cod_upz [name: 'ix_llamadas_upz']
    cod_localidad [name: 'ix_llamadas_localidad']
    rango_hora [name: 'ix_llamadas_franja']
  }

  Note: 'Llamadas123C4.csv — 30 431 filas (2020–2025)'
}

// -----------------------------------------------------------------------------
// Relaciones explícitas (ref inline arriba; resumen)
// -----------------------------------------------------------------------------
// hurtos → calendar, genero, arma_medio
// llamadas_123 → calendar, localidad, upz, franja_horaria
// hurtos -X-> upz (sin relación territorial)

TableGroup dimensiones {
  calendar
  genero
  arma_medio
  localidad
  franja_horaria
  upz
  intervencion
}

TableGroup hechos {
  hurtos_bogota_2025
  llamadas_123
}

